{
  "name": "trading-bot-v5",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "dev:backend": "pnpm --filter backend dev",
    "dev:web": "pnpm --filter web dev",
    "start": "concurrently \"pnpm dev:backend\" \"pnpm dev:web\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "turbo": "^1.13.4"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
